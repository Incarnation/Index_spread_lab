### App
LOG_LEVEL=INFO
TZ=America/New_York
SKIP_STARTUP_WARMUP=false
SKIP_INIT_DB=false
CORS_ORIGINS=http://localhost:5173

### Auth
JWT_SECRET=your-secret-at-least-32-chars-long
AUTH_REGISTER_ENABLED=false

### Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/index_spread_lab

### Tradier
TRADIER_BASE_URL=https://sandbox.tradier.com/v1
TRADIER_ACCESS_TOKEN=replace_me
TRADIER_ACCOUNT_ID=VA000000
MZDATA_BASE_URL=https://mztrading-data.deno.dev

### Ops/Safety
ALLOW_QUOTES_OUTSIDE_RTH=false
ALLOW_SNAPSHOT_OUTSIDE_RTH=false
GEX_ALLOW_OUTSIDE_RTH=false
MARKET_CLOCK_CACHE_SECONDS=300

### Quote schedule
QUOTE_SYMBOLS=SPX,VIX,VIX9D,SPY,VVIX,SKEW
QUOTE_INTERVAL_MINUTES=5

### SPX snapshot schedule
SNAPSHOT_INTERVAL_MINUTES=5
SNAPSHOT_UNDERLYING=SPX
SNAPSHOT_DTE_MODE=range
SNAPSHOT_DTE_MIN_DAYS=0
SNAPSHOT_DTE_MAX_DAYS=10
SNAPSHOT_DTE_TARGETS=3,5,7
SNAPSHOT_DTE_TOLERANCE_DAYS=1
SNAPSHOT_RANGE_FALLBACK_ENABLED=false
SNAPSHOT_RANGE_FALLBACK_COUNT=3
SNAPSHOT_STRIKES_EACH_SIDE=75

### SPY snapshot schedule
SPY_SNAPSHOT_ENABLED=true
SPY_SNAPSHOT_INTERVAL_MINUTES=5
SPY_SNAPSHOT_UNDERLYING=SPY
SPY_SNAPSHOT_DTE_MODE=range
SPY_SNAPSHOT_DTE_MIN_DAYS=0
SPY_SNAPSHOT_DTE_MAX_DAYS=10
SPY_SNAPSHOT_DTE_TARGETS=3,5,7
SPY_SNAPSHOT_DTE_TOLERANCE_DAYS=1
SPY_SNAPSHOT_RANGE_FALLBACK_ENABLED=false
SPY_SNAPSHOT_RANGE_FALLBACK_COUNT=3
SPY_SNAPSHOT_STRIKES_EACH_SIDE=75
SPY_ALLOW_SNAPSHOT_OUTSIDE_RTH=false

### VIX snapshot schedule
VIX_SNAPSHOT_ENABLED=false
VIX_SNAPSHOT_INTERVAL_MINUTES=5
VIX_SNAPSHOT_UNDERLYING=VIX
VIX_SNAPSHOT_DTE_MODE=range
VIX_SNAPSHOT_DTE_MIN_DAYS=0
VIX_SNAPSHOT_DTE_MAX_DAYS=10
VIX_SNAPSHOT_DTE_TARGETS=14,21,28
VIX_SNAPSHOT_DTE_TOLERANCE_DAYS=2
VIX_SNAPSHOT_RANGE_FALLBACK_ENABLED=false
VIX_SNAPSHOT_RANGE_FALLBACK_COUNT=3
VIX_SNAPSHOT_STRIKES_EACH_SIDE=50
VIX_ALLOW_SNAPSHOT_OUTSIDE_RTH=false

### GEX
GEX_ENABLED=true
GEX_INTERVAL_MINUTES=5
GEX_STORE_BY_EXPIRY=true
GEX_SPOT_MAX_AGE_SECONDS=600
GEX_CONTRACT_MULTIPLIER=100
GEX_PUTS_NEGATIVE=true
GEX_SNAPSHOT_BATCH_LIMIT=50
GEX_STRIKE_LIMIT=150
GEX_MAX_DTE_DAYS=10

### CBOE precomputed GEX (parallel source, RTH-only by default)
CBOE_GEX_ENABLED=true
CBOE_GEX_UNDERLYINGS=SPX,SPY,VIX
# Legacy fallback (deprecated): CBOE_GEX_UNDERLYING=SPX
CBOE_GEX_INTERVAL_MINUTES=5
CBOE_GEX_ALLOW_OUTSIDE_RTH=false

### Decision engine
DECISION_ENTRY_TIMES=10:02,11:02,12:02
# 0-DTE removed: backtest showed 10.6% loss rate vs 4.5-7% for other DTEs.
# Skipping 0-DTE raised Sharpe from 21.3 to 25.2. Re-add 0 to re-enable.
DECISION_DTE_TARGETS=3,5,7,10
DECISION_DTE_TOLERANCE_DAYS=0
DECISION_DELTA_TARGETS=0.10,0.20
DECISION_SPREAD_SIDE=put
DECISION_SPREAD_SIDES=put,call
DECISION_SPREAD_WIDTH_POINTS=10
DECISION_CONTRACTS=1
DECISION_SNAPSHOT_MAX_AGE_MINUTES=20
DECISION_MAX_TRADES_PER_RUN=5
DECISION_MAX_TRADES_PER_DAY=20
DECISION_MAX_OPEN_TRADES=20
DECISION_MAX_TRADES_PER_SIDE_PER_DAY=10
DECISION_MAX_OPEN_TRADES_PER_SIDE=10
DECISION_RULESET_VERSION=rules_v1
DECISION_ALLOW_OUTSIDE_RTH=false

### Hybrid policy
DECISION_HYBRID_ENABLED=false
DECISION_HYBRID_MODEL_NAME=spx_credit_spread_v1
DECISION_HYBRID_MIN_EXPECTED_PNL=0.0
DECISION_HYBRID_MIN_PROBABILITY=0.50
DECISION_HYBRID_REQUIRE_ACTIVE_MODEL=true
DECISION_HYBRID_MIN_BUCKET_COUNT=8
DECISION_HYBRID_MAX_PNL_STD=250.0

### Databento (offline downloads only; never commit real keys)
# Used by backend/scripts/download_databento.py for historical CBBO pulls.
DATABENTO_API_KEY=

### Feature/label pipeline
FEATURE_BUILDER_ENABLED=true
FEATURE_BUILDER_ALLOW_OUTSIDE_RTH=false
FEATURE_SCHEMA_VERSION=fs_v2
CANDIDATE_SCHEMA_VERSION=cand_v2
LABELER_ENABLED=true
LABELER_BATCH_LIMIT=200
LABELER_MIN_AGE_MINUTES=10
LABELER_MAX_WAIT_HOURS=336
LABELER_TAKE_PROFIT_PCT=0.50
LABEL_SCHEMA_VERSION=label_v1
LABEL_CONTRACT_MULTIPLIER=100

### Shadow inference / trainer / promotion gate
# SHADOW_INFERENCE_MODEL_NAME and DECISION_HYBRID_MODEL_NAME point at the
# XGBoost entry model (spx_credit_spread_v1).  TRAINER and PROMOTION_GATE
# must stay on cand_bucket_v1 -- the trainer always creates bucket_empirical_v1
# models, and mixing model lineages under one name causes the weekly training
# run to silently replace the XGBoost model.
SHADOW_INFERENCE_ENABLED=true
SHADOW_INFERENCE_MODEL_NAME=spx_credit_spread_v1
SHADOW_INFERENCE_BATCH_LIMIT=500
SHADOW_INFERENCE_LOOKBACK_MINUTES=1440
TRAINER_ENABLED=true
TRAINER_MODEL_NAME=cand_bucket_v1
TRAINER_WEEKDAY=sat
TRAINER_HOUR=9
TRAINER_MINUTE=0
PROMOTION_GATE_ENABLED=true
PROMOTION_GATE_MODEL_NAME=cand_bucket_v1

### Trade PnL
TRADE_PNL_ENABLED=true
TRADE_PNL_INTERVAL_MINUTES=5
TRADE_PNL_ALLOW_OUTSIDE_RTH=false
TRADE_PNL_MARK_MAX_AGE_MINUTES=30
TRADE_PNL_TAKE_PROFIT_PCT=0.50
TRADE_PNL_STOP_LOSS_ENABLED=true
TRADE_PNL_STOP_LOSS_PCT=2.00
TRADE_PNL_CONTRACT_MULTIPLIER=100

### Performance analytics aggregates
PERFORMANCE_ANALYTICS_ENABLED=true
PERFORMANCE_ANALYTICS_INTERVAL_MINUTES=5

### Staleness alerting (RTH-only, cooldown-gated, via SendGrid)
STALENESS_ALERT_ENABLED=true
STALENESS_ALERT_INTERVAL_MINUTES=30
STALENESS_QUOTES_MAX_MINUTES=120
STALENESS_SNAPSHOTS_MAX_MINUTES=120
STALENESS_GEX_MAX_MINUTES=120
STALENESS_DECISIONS_MAX_MINUTES=480
STALENESS_COOLDOWN_MINUTES=360
SENDGRID_API_KEY=
EMAIL_ALERT_RECIPIENT=
EMAIL_ALERT_SENDER=alerts@indexspreadlab.app

### Portfolio-managed capital budgeting
# When enabled, decision_job uses capital-budgeted portfolio management
# instead of the legacy ML/rules pipeline.
PORTFOLIO_ENABLED=false
PORTFOLIO_STARTING_CAPITAL=20000
PORTFOLIO_MAX_TRADES_PER_DAY=2
PORTFOLIO_MAX_TRADES_PER_RUN=1
PORTFOLIO_MONTHLY_DRAWDOWN_LIMIT=0.15
PORTFOLIO_LOT_PER_EQUITY=10000
PORTFOLIO_MAX_EQUITY_RISK_PCT=0.10
PORTFOLIO_MAX_MARGIN_PCT=0.30
PORTFOLIO_CALLS_ONLY=true

### Event-driven signal layer (requires PORTFOLIO_ENABLED=true)
# Detects market drops/VIX spikes and places event-driven trades.
EVENT_ENABLED=false
EVENT_BUDGET_MODE=shared
EVENT_MAX_TRADES=1
EVENT_SPX_DROP_THRESHOLD=-0.005
EVENT_SPX_DROP_2D_THRESHOLD=-0.02
EVENT_VIX_SPIKE_THRESHOLD=0.15
EVENT_VIX_ELEVATED_THRESHOLD=25.0
EVENT_TERM_INVERSION_THRESHOLD=1.0
EVENT_SIDE_PREFERENCE=puts
EVENT_MIN_DTE=3
EVENT_MAX_DTE=7
EVENT_MIN_DELTA=0.10
EVENT_MAX_DELTA=0.25
EVENT_RALLY_AVOIDANCE=true
EVENT_RALLY_THRESHOLD=0.01

### SMS trade notifications (Twilio)
# When enabled, sends text messages on trade opens and closes.
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBERS=
SMS_NOTIFY_SOURCES=all

### Integration tests (optional; must be localhost and DB name must contain "test")
# DATABASE_URL_TEST=postgresql+asyncpg://postgres:postgres@127.0.0.1:5433/index_spread_test

