TRADE_PNL_STOP_LOSS_PCT=1.00
TRADE_PNL_CONTRACT_MULTIPLIER=100
GEX_ENABLED=true
GEX_INTERVAL_MINUTES=5
GEX_STORE_BY_EXPIRY=true
GEX_SPOT_MAX_AGE_SECONDS=600
GEX_CONTRACT_MULTIPLIER=100
GEX_PUTS_NEGATIVE=true
GEX_SNAPSHOT_BATCH_LIMIT=20
GEX_STRIKE_LIMIT=150
GEX_MAX_DTE_DAYS=10
ALLOW_SNAPSHOT_OUTSIDE_RTH=false
ALLOW_QUOTES_OUTSIDE_RTH=false
