.DS_Store

# Environment / secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
*.log

# Virtualenv
.venv/
venv/

# Node / React
frontend/node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# Cursor (may contain secrets like MCP tokens)
.cursor/

# Data / DB artifacts (keep large data out of git)
*.duckdb
*.db
*.sqlite
*.sqlite3
*.parquet
# Ignore everything inside data/ EXCEPT the README documentation and
# the ``archive/`` subtree of historical "tombstone" CSVs we still want
# to track for forensics. Use ``data/*`` (not ``data/``) so git still
# recurses into the directory and the negations below can take effect.
data/*
!data/README.md
!data/archive/
!data/archive/**

